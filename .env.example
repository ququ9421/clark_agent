# ========== 应用配置 ==========
# 被测应用的 URL
APP_URL=https://your-app.example.com

# 测试账号
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=your_password

# 支持的语言（逗号分隔，默认 zh）
APP_LANGUAGES=zh

# ========== 工作目录 ==========
# 测试产物输出目录
QA_WORKSPACE_DIR=./tests/e2e/local

# 被测项目源码目录（用于白盒测试）
SOURCE_PROJECT_DIR=

# ========== GitHub（可选）==========
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
TARGET_BRANCH=main

# ========== Bug 追踪（可选）==========
# Linear
LINEAR_API_KEY=
LINEAR_PROJECT_ID=
LINEAR_TEAM_ID=

# ========== 被测项目 GitHub（/qa-gen-unit, /qa-gen-api）==========
# 配置后优先于 SOURCE_PROJECT_DIR，通过 GitHub Contents API 按需读取文件（无需 clone）
# Token 复用上方 GITHUB_TOKEN；分支复用下方 TARGET_BRANCH
TARGET_GITHUB_URL=https://github.com/your-org/your-repo
TARGET_GITHUB_OWNER=
TARGET_GITHUB_REPO=

# ========== 单元测试（/qa-gen-unit）==========
# 测试框架：vitest / jest（留空则自动检测）
UNIT_TEST_STYLE=

# ========== API 测试（/qa-gen-api）==========
# OpenAPI/Swagger 规格文件路径（优先使用，其次扫描源码）
API_SPEC_PATH=./docs/api-spec.yaml
# API 测试 base URL
TEST_BASE_URL=http://localhost:3000
# Mock 层级：L1 | L2 | L3 | all（默认 all）
API_MOCK_LEVEL=all

# ========== Playwright ==========
PLAYWRIGHT_HEADLESS=true
# Playwright 测试 base URL（留空则自动读取 APP_URL）
PLAYWRIGHT_BASE_URL=
